---
// AnimatedSvgIcon — renders an animated SVG icon from /public/vids/ via <object>.
//
// Conventions:
//   - Expects /public/vids/{name}.svg (produced by scripts/mp4-to-svg.py)
//   - The SVG file contains its own JS frame-cycling animation.
//   - prefers-reduced-motion is handled inside the SVG's own script.
//   - <object> is required (not <img>) — CSS animations inside SVG only
//     run when loaded via <object>, which gives the SVG its own document
//     context with JS access.
//
// Background blending strategy (icons have white backgrounds):
//   Same approach as AnimatedIcon — blend modes on the wrapper, filter on
//   the object. These must stay on separate elements (filter creates an
//   isolated stacking context that breaks mix-blend-mode if combined).
//
//   Light mode: wrapper mix-blend-mode:multiply blends white bg away
//   Dark mode:  object filter:invert(1) flips the colors;
//               wrapper mix-blend-mode:screen removes the now-black bg.

interface Props {
  name: string;
  alt: string;
  size?: number;
  class?: string;
}

const { name, alt, size = 128, class: className } = Astro.props;

const svgSrc = `/vids/${name}.svg`;
---

<span class:list={["animated-svg-wrapper", className]}>
  <object
    class="animated-svg-icon"
    type="image/svg+xml"
    data={svgSrc}
    width={size}
    height={size}
    aria-label={alt}
    role="img"
  ></object>
</span>

<style>
  .animated-svg-wrapper {
    display: inline-block;
    vertical-align: middle;
    mix-blend-mode: multiply;
  }

  .animated-svg-icon {
    display: block;
  }

  :global(.dark) .animated-svg-wrapper {
    mix-blend-mode: screen;
  }

  :global(.dark) .animated-svg-icon {
    filter: invert(1);
  }
</style>
