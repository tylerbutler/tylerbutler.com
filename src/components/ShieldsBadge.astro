---
import { makeBadge } from "badge-maker";

const { label, message, color = "blue", style = "flat", logo } = Astro.props;

// Generate SVG as a string
const svg = String(
  makeBadge({
    label,
    message,
    color,
    style,
    ...(logo ? { logo } : {}),
  }),
);

// Astro requires the SVG to be wrapped in a container
// to avoid parser issues with top-level <svg>
---

<div class="badge">
  <Fragment set:html={svg} />
</div>

<style>
  .badge :global(svg) {
    display: inline-block;
  }

  .badge {
    text-decoration: none;
    text-transform: none;
    display: inline-block;
    margin-right: 0.5em;
  }
</style>
