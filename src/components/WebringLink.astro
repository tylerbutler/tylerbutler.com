---
import { Webring } from "../lib/tinylytics";

interface Props {
  label?: string;
  size?: "small" | "large";
  class?: string;
}

const {
  label = "Visit a random site →",
  size = "small",
  class: className,
} = Astro.props;
---

<Webring
  avatar
  class:list={[`webring-${size}`, className]}
>
  <span class="webring-label">{label}</span>
</Webring>

<script>
  // Augment each webring link with event-tracking attributes after render so
  // a click is also captured as a Tinylytics event.
  for (const el of document.querySelectorAll<HTMLElement>(".tinylytics_webring")) {
    if (!el.dataset.tinylyticsEvent) {
      el.dataset.tinylyticsEvent = "webring.click";
      el.dataset.tinylyticsEventValue = "random";
    }
  }
</script>

<style>
  .tinylytics_webring {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .tinylytics_webring_avatar {
    border-radius: 50%;
    object-fit: cover;
    vertical-align: middle;
  }

  .webring-small .tinylytics_webring_avatar {
    width: 32px;
    height: 32px;
  }

  .webring-large {
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .webring-large .tinylytics_webring_avatar {
    width: 96px;
    height: 96px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.15);
  }

  .webring-large .webring-label {
    font-size: 1.15rem;
    font-style: italic;
  }
</style>
