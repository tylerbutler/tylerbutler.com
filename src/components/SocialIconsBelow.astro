---
import { Icon } from "astro-icon/components";
---

<div class="social-icons-below">
  <a href="https://github.com/tylerbutler" class="social-link" title="GitHub" target="_blank" rel="noopener me">
    <Icon name="iconoir:github" aria-hidden="true" />
    <span class="sr-only">GitHub</span>
  </a>
  <a href="mailto:tyler@tylerbutler.com" class="social-link" title="Email" rel="me">
    <Icon name="iconoir:mail" aria-hidden="true" />
    <span class="sr-only">Email</span>
  </a>
  <a href="/feed.xml" class="social-link" title="Feed">
    <Icon name="iconoir:rss-feed" aria-hidden="true" />
    <span class="sr-only">Feed</span>
  </a>
</div>

<style>
  .social-icons-below {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 4px 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-links);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 3px;
  }

  .social-link:hover {
    color: var(--accent);
    background-color: rgba(212, 175, 55, 0.1);
  }

  .social-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .social-link [data-icon] {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Screen reader only text */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
