---
interface Props {
  path: string;
  variant?: "article" | "preview";
}

const { path, variant = "article" } = Astro.props;
const Tag = variant === "article" ? "div" : "span";
const wrapperClass = variant === "article" ? "article-kudos" : "preview-kudos";
---

<Tag class={wrapperClass}>
  <button class="tinylytics_kudos" data-path={path} type="button">
    <span class="kudos-label">I like this</span>
  </button>
  <span class="kudos-suffix" hidden>
    — and so do <span class="kudos-count"></span> others
  </span>
</Tag>

<script>
  const KUDOS_THRESHOLD = 10;
  const TINYLYTICS_BIND_TIMEOUT_MS = 5000;

  function setLabel(btn: HTMLElement, text: string) {
    btn.replaceChildren();
    const label = document.createElement("span");
    label.className = "kudos-label";
    label.textContent = text;
    btn.appendChild(label);
  }

  function markLiked(btn: HTMLElement) {
    if (btn.dataset.kudosLiked === "true") return;
    btn.dataset.kudosLiked = "true";
    setLabel(btn, "Liked!");
  }

  function processKudos(btn: HTMLElement) {
    if (btn.classList.contains("did_select") || btn.dataset.kudosLiked === "true") {
      markLiked(btn);
      return;
    }

    const digits = btn.textContent?.match(/\d+/)?.[0];
    const parent = btn.parentElement;
    const suffix = parent?.querySelector<HTMLElement>(".kudos-suffix") ?? null;
    const countEl = parent?.querySelector<HTMLElement>(".kudos-count") ?? null;

    if (digits === undefined) {
      if (!btn.querySelector(".kudos-label")) {
        setLabel(btn, "I like this");
      }
      return;
    }

    const count = Number.parseInt(digits, 10);
    if (!Number.isFinite(count)) return;

    setLabel(btn, "I like this");

    if (count > KUDOS_THRESHOLD && suffix && countEl) {
      countEl.textContent = String(count);
      suffix.hidden = false;
    } else if (suffix) {
      suffix.hidden = true;
    }
  }

  function initKudosButton(btn: HTMLElement) {
    processKudos(btn);

    const observer = new MutationObserver(() => {
      observer.disconnect();
      processKudos(btn);
      observer.observe(btn, {
        childList: true,
        characterData: true,
        subtree: true,
      });
    });
    observer.observe(btn, {
      childList: true,
      characterData: true,
      subtree: true,
    });

    // Watch for tinylytics adding did_select via class change
    const attrObserver = new MutationObserver(() => {
      if (btn.classList.contains("did_select")) {
        markLiked(btn);
      }
    });
    attrObserver.observe(btn, { attributes: true, attributeFilter: ["class"] });

    btn.addEventListener("click", () => {
      btn.classList.remove("is-launching");
      void btn.offsetWidth;
      btn.classList.add("is-launching");
    });
    btn.addEventListener("animationend", (event) => {
      if (event.animationName === "kudos-rocket-launch") {
        btn.classList.remove("is-launching");
      }
    });

    // Fallback: if tinylytics never binds, handle the click ourselves
    setTimeout(() => {
      if (btn.dataset.tinylyticsKudosBound === "true") return;
      btn.addEventListener("click", () => {
        if (btn.dataset.kudosLiked === "true") return;
        markLiked(btn);
        (btn as HTMLButtonElement).disabled = true;
        btn.setAttribute("aria-disabled", "true");
        btn.classList.add("did_select");
      });
    }, TINYLYTICS_BIND_TIMEOUT_MS);
  }

  for (const btn of document.querySelectorAll<HTMLElement>(
    ".tinylytics_kudos",
  )) {
    initKudosButton(btn);
  }
</script>
