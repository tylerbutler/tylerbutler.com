---
import { Icon } from "astro-icon/components";
import Bluesky from "simple-icons-astro/Bluesky";
---

<div class="social-icons-below">
  <a href="https://github.com/tylerbutler" class="social-link" title="GitHub" target="_blank" rel="noopener me" data-tinylytics-event="social.github" data-tinylytics-event-value="https://github.com/tylerbutler">
    <Icon name="iconoir:github" aria-hidden="true" />
    <span class="sr-only">GitHub</span>
  </a>
  <a href="https://hachyderm.io/@tyler" class="social-link" title="Mastodon" target="_blank" rel="noopener me" data-tinylytics-event="social.mastodon" data-tinylytics-event-value="https://hachyderm.io/@tyler">
    <Icon name="iconoir:mastodon" aria-hidden="true" />
    <span class="sr-only">Mastodon</span>
  </a>
  <a href="https://bsky.app/profile/tylerbutler.bsky.social" class="social-link" title="Bluesky" target="_blank" rel="noopener me" data-tinylytics-event="social.bluesky" data-tinylytics-event-value="https://bsky.app/profile/tylerbutler.bsky.social">
    <Bluesky fill="currentColor" aria-hidden="true" />
    <span class="sr-only">Bluesky</span>
  </a>
  <a href="mailto:tyler@tylerbutler.com" class="social-link" title="Email" rel="me" data-tinylytics-event="social.email" data-tinylytics-event-value="tyler@tylerbutler.com">
    <Icon name="iconoir:mail" aria-hidden="true" />
    <span class="sr-only">Email</span>
  </a>
  <a href="/feed.xml" class="social-link" title="Feed" data-tinylytics-event="social.feed" data-tinylytics-event-value="/feed.xml">
    <Icon name="iconoir:rss-feed" aria-hidden="true" />
    <span class="sr-only">Feed</span>
  </a>
  <a href="/webring" class="social-link" title="Webring" data-tinylytics-event="social.webring" data-tinylytics-event-value="/webring">
    <Icon name="iconoir:globe" aria-hidden="true" />
    <span class="sr-only">Webring</span>
  </a>
</div>

<style>
  .social-icons-below {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 4px 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-links);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 3px;
  }

  .social-link:hover {
    color: var(--accent);
    background-color: rgba(212, 175, 55, 0.1);
  }

  .social-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .social-link svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Screen reader only text */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
