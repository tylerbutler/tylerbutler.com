{
  "name": "tylerbutler.com",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/tylerbutler/tylerbutler.com-hugo#readme",
  "bugs": {
    "url": "https://github.com/tylerbutler/tylerbutler.com-hugo/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tylerbutler/tylerbutler.com-hugo.git"
  },
  "license": "MIT",
  "author": "Tyler Butler <tyler@tylerbutler.com>",
  "type": "module",
  "scripts": {
    "astro": "astro",
    "baseline": "npm run baseline:build && npm run baseline:lighthouse && npm run baseline:accessibility && npm run baseline:bundle",
    "baseline:accessibility": "npm run test:accessibility",
    "baseline:build": "npm run build",
    "baseline:bundle": "npm run test:bundle",
    "baseline:lighthouse": "npm run test:lighthouse && npm run test:lighthouse:mobile",
    "build": "cross-env GITHUB_REPO_OWNER=tylerbutler GITHUB_REPO_NAME=private-resources astro build",
    "check": "astro check --minimumSeverity warning",
    "dev": "astro dev",
    "format": "biome check --write --linter-enabled=false",
    "linkcheck": "start-server-and-test dev http://localhost:4321 'cat complete-urls.txt | xargs lychee'",
    "optimize:fonts": "node scripts/optimize-fonts.mjs",
    "serve": "serve dist -l 4173",
    "test": "npm run test:visual && npm run test:performance && npm run test:accessibility && npm run test:bundle",
    "test:accessibility": "start-server-and-test serve http://localhost:4173 'pa11y-ci'",
    "test:bundle": "NODE_ENV=production npm run build && echo \"📊 Bundle analysis generated at dist/bundle-analysis.html\"",
    "test:headed": "playwright test --headed",
    "test:lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "test:lighthouse:mobile": "lhci autorun --config=lighthouserc.mobile.cjs",
    "test:performance": "npm run test:lighthouse",
    "test:update": "playwright test --update-snapshots",
    "test:visual": "playwright test tests/visual"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@benjifs/github-store": "^0.2.0",
    "@benjifs/micropub": "^2.0.1",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@floating-ui/dom": "^1.7.6",
    "@fontsource/lato": "^5.2.7",
    "@iconify-json/iconoir": "^1.2.10",
    "@lucide/astro": "^1.8.0",
    "@netlify/api": "^14.0.18",
    "astro": "^6.1.5",
    "astro-broken-links-checker": "github:imazen/astro-broken-link-checker",
    "astro-expressive-code": "^0.41.7",
    "astro-icon": "^1.1.5",
    "astro-toc": "^0.2.0",
    "expressive-code-twoslash": "^0.6.1",
    "littlefoot": "^4.1.3",
    "lottie-web": "^5.13.0",
    "pathe": "^2.0.3",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-expressive-code": "^0.41.7",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.1.0",
    "remark-mermaid": "^0.2.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-shift-headings": "^0.1.1",
    "remark-smartypants": "^3.0.2",
    "remark-stringify": "^11.0.0",
    "sanitize-html": "^2.17.2",
    "simple-icons-astro": "^16.1.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "cross-env": "^10.1.0",
    "pa11y-ci": "^4.1.0",
    "pagefind": "^1.5.0",
    "postcss-nesting": "^14.0.0",
    "rehype-footnotes": "^0.1.2",
    "remark-lazy-links": "^0.1.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "serve": "^14.2.6",
    "sharp": "^0.34.5",
    "start-server-and-test": "^3.0.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0"
}
