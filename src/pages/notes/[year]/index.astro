---
import { getCollection, render } from "astro:content";
import NoteDate from "../../../components/NoteDate.astro";
import NotePermalink from "../../../components/NotePermalink.astro";
import NoteSourceIcon from "../../../components/NoteSourceIcon.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { includeDraft } from "../../../lib/draft-utils";
import {
  getNoteMonthUrl,
  getNotePathParts,
  getNoteUrl,
  getNoteYearUrl,
  monthLabel,
} from "../../../lib/note-utils";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => includeDraft(data));

  const byYear = new Map<
    string,
    Array<{ note: (typeof notes)[number]; month: string; day: string }>
  >();
  for (const note of notes) {
    const { year, month, day } = getNotePathParts(note);
    if (!byYear.has(year)) byYear.set(year, []);
    byYear.get(year)!.push({ note, month, day });
  }

  const years = [...byYear.keys()].sort();

  return years.map((year, idx) => {
    const items = byYear
      .get(year)!
      .sort((a, b) => b.note.data.date.getTime() - a.note.data.date.getTime());
    return {
      params: { year },
      props: {
        items,
        prevYear: idx > 0 ? years[idx - 1] : null,
        nextYear: idx < years.length - 1 ? years[idx + 1] : null,
      },
    };
  });
}

const { year } = Astro.params;
const { items, prevYear, nextYear } = Astro.props;

const groupedByMonth = new Map<string, typeof items>();
for (const item of items) {
  if (!groupedByMonth.has(item.month)) groupedByMonth.set(item.month, []);
  groupedByMonth.get(item.month)!.push(item);
}
const months = [...groupedByMonth.keys()].sort().reverse();

const renderedByMonth = await Promise.all(
  months.map(async (month) => {
    const monthItems = groupedByMonth.get(month)!;
    const rendered = await Promise.all(
      monthItems.map(async (item) => {
        const { Content } = await render(item.note);
        return { ...item, Content };
      }),
    );
    return { month, items: rendered };
  }),
);
---

<BaseLayout
  title={`Notes from ${year} - Tyler Butler`}
  description={`Short-form notes from ${year}.`}
>
  <section class="notes-page h-feed">
    <nav class="archive-crumbs">
      <a href="/notes/">Notes</a> / <span>{year}</span>
    </nav>
    <h1>Notes from {year}</h1>
    <p class="archive-count">
      {items.length} note{items.length === 1 ? "" : "s"}
    </p>

    {
      renderedByMonth.map(({ month, items: monthItems }) => (
        <section class="archive-month">
          <h2>
            <a href={getNoteMonthUrl(year, month)}>{monthLabel(month)}</a>
          </h2>
          <div class="notes-stream">
            {monthItems.map(({ note, Content }) => {
              const url = getNoteUrl(note);
              return (
                <article class="note-item h-entry">
                  <header class="note-item-header">
                    {note.data.title && (
                      <h3 class="p-name">
                        <a href={url} class="u-url">
                          {note.data.title}
                        </a>
                      </h3>
                    )}
                    <span class="note-meta">
                      <NoteSourceIcon source={note.data.source} />
                      <NoteDate note={note} className="note-permalink" />
                      <NotePermalink note={note} />
                    </span>
                  </header>

                  <div class="note-item-content e-content">
                    <Content />
                  </div>

                  {note.data.tags && note.data.tags.length > 0 && (
                    <div class="note-item-tags">
                      {note.data.tags.map((tag) => (
                        <a href={`/tags/${tag}/`} class="tag p-category">
                          #{tag}
                        </a>
                      ))}
                    </div>
                  )}
                </article>
              );
            })}
          </div>
        </section>
      ))
    }

    <nav class="article-nav">
      {
        prevYear && (
          <a href={getNoteYearUrl(prevYear)} class="nav-link">
            <span class="nav-arrow">←</span>
            <span class="nav-text">{prevYear}</span>
          </a>
        )
      }
      {
        nextYear && (
          <a
            href={getNoteYearUrl(nextYear)}
            class="nav-link nav-link-next"
          >
            <span class="nav-text">{nextYear}</span>
            <span class="nav-arrow">→</span>
          </a>
        )
      }
    </nav>
  </section>
</BaseLayout>

<style>
  .notes-page {
    max-width: 65ch;
    margin: 0 auto;
  }

  .archive-crumbs {
    font-size: 14px;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .archive-crumbs a {
    color: var(--text-light);
    text-decoration: none;
  }

  .archive-crumbs a:hover {
    color: var(--accent);
  }

  .archive-count {
    color: var(--text-light);
    font-size: 14px;
    margin-top: -0.5rem;
  }

  .archive-month {
    margin-top: 2.5rem;
  }

  .archive-month h2 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    border-bottom: 1px solid var(--border, #ddd);
    padding-bottom: 0.25rem;
  }

  .archive-month h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .archive-month h2 a:hover {
    color: var(--accent);
  }

  .notes-stream {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 1rem;
  }

  .note-item {
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border, #ddd);
  }

  .note-item:last-child {
    border-bottom: none;
  }

  .note-item-header {
    margin-bottom: 0.5rem;
  }

  .note-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .note-item-header h3 {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
  }

  .note-item-header h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .note-item-header h3 a:hover {
    color: var(--accent);
  }

  .note-item-content {
    line-height: 1.6;
  }

  .note-item-tags {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
    text-decoration: none;
    font-size: 13px;
  }

  .tag:hover {
    text-decoration: underline;
  }
</style>
