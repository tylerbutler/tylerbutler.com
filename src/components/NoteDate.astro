---
import type { CollectionEntry } from "astro:content";
import {
  getNoteMonthUrl,
  getNotePathParts,
  getNoteUrl,
  getNoteYearUrl,
  monthLabel,
} from "../lib/note-utils";

interface Props {
  note: CollectionEntry<"notes">;
  className?: string;
}

const { note, className } = Astro.props;
const { year, month, day } = getNotePathParts(note);
const isoDate = note.data.date.toISOString();
const dayNumber = Number.parseInt(day, 10);
---

<time class:list={["note-date dt-published", className]} datetime={isoDate}>
  <a href={getNoteMonthUrl(year, month)}>{monthLabel(month)}</a>
  {" "}
  <a href={getNoteUrl(note)} class="u-url">{dayNumber}</a>,
  {" "}
  <a href={getNoteYearUrl(year)}>{year}</a>
</time>

<style>
  .note-date {
    font-size: 13px;
    color: var(--text-light);
    font-variant-numeric: tabular-nums;
  }

  .note-date a {
    color: inherit;
    text-decoration: none;
  }

  .note-date a:hover {
    color: var(--accent);
  }
</style>
