---
interface Props {
  embedCode: string;
  kudos?: boolean | "custom";
  hits?: boolean | "unique";
  webmention?: boolean;
}

const {
  embedCode,
  kudos = false,
  hits = false,
  webmention = false,
} = Astro.props;

const flags: string[] = [];
if (kudos === "custom") flags.push("kudos=custom");
else if (kudos === true) flags.push("kudos");
if (hits === "unique") flags.push("hits=unique");
else if (hits === true) flags.push("hits");

const query = flags.length > 0 ? `?${flags.join("&")}` : "";
const scriptSrc = `https://tinylytics.app/embed/${embedCode}.js${query}`;
const webmentionHref = `https://tinylytics.app/webmention/${embedCode}`;
---

{webmention && <link rel="webmention" href={webmentionHref} />}
<script src={scriptSrc} defer is:inline></script>
