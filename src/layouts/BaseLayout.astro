---
import BrokenLinkTooltip from "../components/BrokenLinkTooltip.astro";
import Footer from "../components/Footer.astro";
import FootnoteScript from "../components/FootnotesScript.astro";
import Header from "../components/Header.astro";
import "../lib/styles/global.css";
import "../styles/fonts.css";

export interface Props {
  title?: string;
  description?: string;
  headerSize?: "large" | "small";
  canonicalUrl?: string;
}

const {
  title = "Tyler Butler",
  description = "Personal website and blog of Tyler Butler",
  headerSize = "large",
  canonicalUrl,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8">
    <link rel="icon" type="image/x-icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="generator" content={Astro.generator}>
    <title>{title}</title>
    <meta name="description" content={description}>
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <link rel="stylesheet" href="https://use.typekit.net/zsx5vsn.css">
    <link
      rel="preload"
      href="/fonts/PragmataPro_Mono_R_liga_0902.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    >
    <!-- IndieAuth -->
    <link rel="authorization_endpoint" href="https://indieauth.com/auth" />
    <link rel="token_endpoint" href="https://tokens.indieauth.com/token" />
    <!-- IndieWeb endpoints -->
    <link rel="micropub" href="https://tylerbutler.com/micropub" />
    <link rel="webmention" href="https://tinylytics.app/webmention/7vP3rWZsVnwMyLpSbFxs" />
    <!-- rel="me" for IndieAuth identity verification -->
    <link rel="me" href="https://github.com/tylerbutler" />
    <link rel="me" href="mailto:tyler@tylerbutler.com" />
    <!-- Analytics -->
    <script src="https://tinylytics.app/embed/7vP3rWZsVnwMyLpSbFxs.js?kudos&hits" defer></script>
  </head>
  <body>
    <div class="site-container">
      <Header size={headerSize}/>
      <main class="content-section" data-pagefind-body>
        <div class="content-inner">
          <slot/>
        </div>
      </main>
      <Footer/>
    </div>
    <FootnoteScript/>
    <BrokenLinkTooltip/>
    <script>
      // Hide tinylytics kudos count unless it's greater than this threshold.
      // The rocket emoji is rendered via a CSS ::before pseudo-element, so
      // clearing the button's text content still leaves the icon visible.
      const KUDOS_THRESHOLD = 10;

      function updateKudosVisibility(btn: HTMLElement) {
        const text = btn.textContent?.trim() ?? "";
        const match = text.match(/\d+/);
        if (!match) return;
        const count = Number.parseInt(match[0], 10);
        if (count <= KUDOS_THRESHOLD && text.length > 0) {
          btn.textContent = "";
        }
      }

      for (const btn of document.querySelectorAll<HTMLElement>(".tinylytics_kudos")) {
        updateKudosVisibility(btn);
        const observer = new MutationObserver(() => updateKudosVisibility(btn));
        observer.observe(btn, { childList: true, characterData: true, subtree: true });
      }
    </script>
  </body>
</html>
