---
// LottieIcon — renders a Lottie JSON animation from /public/vids/lottie/.
//
// Uses lottie-web to load and animate the JSON file client-side.
// Multiple instances on the same page are all initialized by a single
// shared module script that queries by data attribute.
//
// prefers-reduced-motion: animation is not started if the user has
// requested reduced motion.

interface Props {
  name: string;
  alt: string;
  size?: number;
  loop?: boolean;
  class?: string;
}

const { name, alt, size = 128, loop = true, class: className } = Astro.props;
const src = `/vids/lottie/${name}.json`;
---

<div
  class:list={["lottie-icon-wrapper", className]}
  data-lottie-src={src}
  data-lottie-loop={loop ? "true" : "false"}
  style={`width:${size}px;height:${size}px`}
  role="img"
  aria-label={alt}
></div>

<script>
  // lottie-web is UMD-only. Vite may evaluate the factory in a Node context
  // where `document` is undefined, causing the module to export {}. To work
  // around this, we use a dynamic import so the module is evaluated in the
  // browser, and we pre-fetch the JSON ourselves and pass `animationData`
  // instead of `path` to avoid lottie's internal XHR loader.

  async function initLottieIcons() {
    const { default: lottie } = await import("lottie-web");
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    const els = document.querySelectorAll<HTMLElement>(
      ".lottie-icon-wrapper[data-lottie-src]:not([data-lottie-init])",
    );

    await Promise.all(
      Array.from(els).map(async (el) => {
        el.dataset.lottieInit = "true";
        const animationData = await fetch(el.dataset.lottieSrc!).then((r) => r.json());
        lottie.loadAnimation({
          container: el,
          renderer: "svg",
          loop: el.dataset.lottieLoop === "true",
          autoplay: !reduced,
          animationData,
        });
      }),
    );
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLottieIcons);
  } else {
    initLottieIcons();
  }
</script>

<style>
  .lottie-icon-wrapper {
    display: inline-block;
    vertical-align: middle;
  }
</style>
