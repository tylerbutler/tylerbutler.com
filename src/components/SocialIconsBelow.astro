---
// Simple social icons component for positioning below subtitle
import { Mail, Rss } from "@lucide/astro";
import tablerGithubRaw from "@tabler/icons/outline/brand-github.svg?raw";
import tablerLetterboxdRaw from "@tabler/icons/outline/brand-letterboxd.svg?raw";
import tablerLinkedinRaw from "@tabler/icons/outline/brand-linkedin.svg?raw";
import Github from "simple-icons-astro/Github";

// Strip width/height/class so CSS controls sizing, add social-icon class
const cleanTabler = (raw: string) =>
  raw
    .replace(/ width="\d+"/, "")
    .replace(/ height="\d+"/, "")
    .replace(/ class="[^"]*"/, ' class="social-icon"');

const tablerGithub = cleanTabler(tablerGithubRaw);
const tablerLinkedin = cleanTabler(tablerLinkedinRaw);
const tablerLetterboxd = cleanTabler(tablerLetterboxdRaw);
---

<div class="social-icons-below">
  <!-- Current icons -->
  <a href="https://github.com/tylerbutler" class="social-link social-link--github" title="GitHub (current: simple-icons)" target="_blank" rel="noopener me">
    <Github class="social-icon" />
    <span class="sr-only">GitHub</span>
  </a>
  <a href="mailto:tyler@tylerbutler.com" class="social-link social-link--email" title="Email" rel="me">
    <Mail class="social-icon" />
    <span class="sr-only">Email</span>
  </a>
  <a href="/feed.xml" class="social-link social-link--feed" title="Feed">
    <Rss class="social-icon" />
    <span class="sr-only">Feed</span>
  </a>
</div>

<!-- TEMPORARY: Tabler icon comparison -->
<div class="social-icons-below social-icons-comparison">
  <span class="comparison-label">Tabler →</span>
  <!-- Tabler: brand-github -->
  <a href="https://github.com/tylerbutler" class="social-link" title="GitHub (Tabler)" target="_blank" rel="noopener me">
    <Fragment set:html={tablerGithub} />
    <span class="sr-only">GitHub (Tabler)</span>
  </a>
  <!-- Tabler: brand-linkedin -->
  <a href="https://linkedin.com/in/tylerbutler" class="social-link" title="LinkedIn (Tabler)" target="_blank" rel="noopener me">
    <Fragment set:html={tablerLinkedin} />
    <span class="sr-only">LinkedIn (Tabler)</span>
  </a>
  <!-- Tabler: brand-letterboxd -->
  <a href="https://letterboxd.com/tylerbutler" class="social-link" title="Letterboxd (Tabler)" target="_blank" rel="noopener me">
    <Fragment set:html={tablerLetterboxd} />
    <span class="sr-only">Letterboxd (Tabler)</span>
  </a>
</div>

<style>
  .social-icons-below {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 4px 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-links);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 3px;
  }

  .social-link:hover {
    color: var(--accent);
    background-color: rgba(212, 175, 55, 0.1);
  }

  .social-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .social-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .comparison-label {
    font-size: 10px;
    opacity: 0.5;
    font-family: monospace;
  }

  /* Screen reader only text */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
