---
// Simple social icons component for positioning below subtitle
import tablerGithubRaw from "@tabler/icons/outline/brand-github.svg?raw";
import tablerMailRaw from "@tabler/icons/outline/mail.svg?raw";
import tablerRssRaw from "@tabler/icons/outline/rss.svg?raw";

// Set explicit size and strip tabler classes
const cleanTabler = (raw: string) =>
  raw
    .replace(/\s+width="\d+"/, ' width="16"')
    .replace(/\s+height="\d+"/, ' height="16"')
    .replace(/ class="[^"]*"/, "");

const tablerGithub = cleanTabler(tablerGithubRaw);
const tablerMail = cleanTabler(tablerMailRaw);
const tablerRss = cleanTabler(tablerRssRaw);
---

<div class="social-icons-below">
  <a href="https://github.com/tylerbutler" class="social-link" title="GitHub" target="_blank" rel="noopener me">
    <span class="tabler-icon"><Fragment set:html={tablerGithub} /></span>
    <span class="sr-only">GitHub</span>
  </a>
  <a href="mailto:tyler@tylerbutler.com" class="social-link" title="Email" rel="me">
    <span class="tabler-icon"><Fragment set:html={tablerMail} /></span>
    <span class="sr-only">Email</span>
  </a>
  <a href="/feed.xml" class="social-link" title="Feed">
    <span class="tabler-icon"><Fragment set:html={tablerRss} /></span>
    <span class="sr-only">Feed</span>
  </a>
</div>

<style>
  .social-icons-below {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 4px 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-links);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 3px;
  }

  .social-link:hover {
    color: var(--accent);
    background-color: rgba(212, 175, 55, 0.1);
  }

  .social-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .tabler-icon {
    display: contents;
  }

  .tabler-icon svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Screen reader only text */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
