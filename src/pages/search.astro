---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Search - Tyler Butler"
  description="Search Tyler Butler's articles and projects"
  headerSize="small"
>
  <div class="search-page">
    <h1>Search</h1>
    <pagefind-input placeholder="Search..." autofocus></pagefind-input>
    <pagefind-summary></pagefind-summary>
    <pagefind-filter-dropdown filter="tag" label="Tag"></pagefind-filter-dropdown>
    <pagefind-results show-sub-results></pagefind-results>
  </div>
</BaseLayout>

<style>
  .search-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .search-page h1 {
    margin-bottom: 2rem;
  }
</style>
