---
// Simple social icons component for positioning below subtitle
import { Github, Mail, Rss } from "@lucide/astro";

const socialItems = [
  {
    href: "https://github.com/tylerbutler",
    label: "GitHub",
    icon: "github",
    external: true,
    me: true,
  },
  {
    href: "https://hachyderm.io/@tyler",
    label: "Mastodon",
    icon: "mastodon",
    external: true,
    me: true,
  },
  {
    href: "mailto:tyler@tylerbutler.com",
    label: "Email",
    icon: "email",
    external: false,
    me: true,
  },
  {
    href: "/feed.xml",
    label: "Feed",
    icon: "feed",
    external: false,
    me: false,
  },
];
---

<div class="social-icons-below">
  {socialItems.map(item => (
    <a
      href={item.href}
      class={`social-link social-link--${item.icon}`}
      title={item.label}
      target={item.external ? '_blank' : undefined}
      rel={[item.external && 'noopener', item.me && 'me'].filter(Boolean).join(' ') || undefined}
    >
      {item.icon === 'github' && (
        <Github class="social-icon" />
      )}

      {item.icon === 'mastodon' && (
        <svg
          class="social-icon"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M21.58 13.913c-.29 1.469-2.592 3.121-5.238 3.396-1.379.184-2.737.368-4.185.276-2.369-.092-4.238-.551-4.238-.551 0 .184.015.458.045.642.307 2.387 2.319 2.479 4.228 2.571 1.923.092 3.632-.459 3.632-.459l.077 1.745s-1.34.735-3.738.918c-1.308.093-2.952.183-4.863-.367-4.146-1.194-4.859-5.78-4.967-10.434-.031-1.373-.015-2.698.031-3.795C2.593 3.02 5.25 1.738 8.51 1.738c1.67 0 3.248.459 4.308 1.102.993-.643 2.566-1.102 4.247-1.102 3.26 0 5.916 1.282 6.18 4.842.046 1.097.061 2.422.031 3.795-.046 1.09-.108 2.073-.696 3.538zM18.01 7.05c0-.918-.23-1.376-.783-1.836-.538-.459-1.346-.734-2.32-.734-1.108 0-1.985.459-2.504 1.376l-.595 1.009-.595-1.009c-.52-.917-1.396-1.376-2.504-1.376-.974 0-1.783.275-2.32.734-.552.46-.783.918-.783 1.836v5.787h1.967V7.233c0-.918.399-1.376 1.184-1.376.858 0 1.3.551 1.3 1.653v2.75h1.95V7.51c0-1.102.443-1.653 1.3-1.653.785 0 1.184.459 1.184 1.376v5.604H18.01V7.05z"/>
        </svg>
      )}

      {item.icon === 'email' && (
        <Mail class="social-icon" />
      )}

      {item.icon === 'feed' && (
        <Rss class="social-icon" />
      )}


      <span class="sr-only">{item.label}</span>
    </a>
  ))}
</div>

<style>
  .social-icons-below {
    display: flex;
    gap: 8px;
    justify-content: center;
    align-items: center;
    margin: 8px 0 4px 0;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-links);
    text-decoration: none;
    transition: all 0.2s ease;
    padding: 4px;
    border-radius: 3px;
  }

  .social-link:hover {
    color: var(--accent);
    background-color: rgba(212, 175, 55, 0.1);
  }

  .social-link:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 3px;
  }

  .social-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  /* Screen reader only text */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
