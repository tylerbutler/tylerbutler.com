---
import { getCollection, render } from "astro:content";
import NoteDate from "../../../../components/NoteDate.astro";
import NotePermalink from "../../../../components/NotePermalink.astro";
import NoteSourceIcon from "../../../../components/NoteSourceIcon.astro";
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { includeDraft } from "../../../../lib/draft-utils";
import "../../../../lib/styles/page-nav.css";
import {
  getNoteMonthUrl,
  getNotePathParts,
  getNoteUrl,
  getNoteYearUrl,
  monthLabel,
} from "../../../../lib/note-utils";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => includeDraft(data));

  const byKey = new Map<
    string,
    {
      year: string;
      month: string;
      items: Array<{ note: (typeof notes)[number]; day: string }>;
    }
  >();
  for (const note of notes) {
    const { year, month, day } = getNotePathParts(note);
    const key = `${year}-${month}`;
    if (!byKey.has(key)) byKey.set(key, { year, month, items: [] });
    byKey.get(key)!.items.push({ note, day });
  }

  const keys = [...byKey.keys()].sort();

  return keys.map((key, idx) => {
    const { year, month, items } = byKey.get(key)!;
    items.sort(
      (a, b) => b.note.data.date.getTime() - a.note.data.date.getTime(),
    );
    const prev = idx > 0 ? byKey.get(keys[idx - 1])! : null;
    const next = idx < keys.length - 1 ? byKey.get(keys[idx + 1])! : null;
    return {
      params: { year, month },
      props: {
        items,
        prev: prev ? { year: prev.year, month: prev.month } : null,
        next: next ? { year: next.year, month: next.month } : null,
      },
    };
  });
}

const { year, month } = Astro.params;
const { items, prev, next } = Astro.props;

const heading = `${monthLabel(month)} ${year}`;

const renderedItems = await Promise.all(
  items.map(async (item) => {
    const { Content } = await render(item.note);
    return { ...item, Content };
  }),
);
---

<BaseLayout
  title={`Notes from ${heading} - Tyler Butler`}
  description={`Short-form notes from ${heading}.`}
>
  <section class="notes-page h-feed">
    <nav class="archive-crumbs">
      <a href="/notes/">Notes</a> /{" "}
      <a href={getNoteYearUrl(year)}>{year}</a> /{" "}
      <span>{monthLabel(month)}</span>
    </nav>
    <h1>{heading}</h1>
    <p class="archive-count">
      {items.length} note{items.length === 1 ? "" : "s"}
    </p>

    <div class="notes-stream">
      {
        renderedItems.map(({ note, Content }) => {
          const url = getNoteUrl(note);
          return (
            <article class="note-card h-entry">
              <header class="note-card-header">
                {note.data.title && (
                  <h2 class="p-name">
                    <a href={url} class="u-url">
                      {note.data.title}
                    </a>
                  </h2>
                )}
                <span class="note-meta">
                  <NoteSourceIcon source={note.data.source} />
                  <NoteDate note={note} className="note-permalink" />
                  <NotePermalink note={note} />
                </span>
              </header>

              <div class="note-card-content e-content">
                <Content />
              </div>

              {note.data.tags && note.data.tags.length > 0 && (
                <div class="note-card-tags">
                  {note.data.tags.map((tag) => (
                    <a href={`/tags/${tag}/`} class="tag p-category">
                      #{tag}
                    </a>
                  ))}
                </div>
              )}
            </article>
          );
        })
      }
    </div>

    <nav class="article-nav">
      {
        prev && (
          <a
            href={getNoteMonthUrl(prev.year, prev.month)}
            class="nav-link"
          >
            <span class="nav-arrow">←</span>
            <span class="nav-text">
              {monthLabel(prev.month)} {prev.year}
            </span>
          </a>
        )
      }
      {
        next && (
          <a
            href={getNoteMonthUrl(next.year, next.month)}
            class="nav-link nav-link-next"
          >
            <span class="nav-text">
              {monthLabel(next.month)} {next.year}
            </span>
            <span class="nav-arrow">→</span>
          </a>
        )
      }
    </nav>
  </section>
</BaseLayout>

<style>
  .notes-page {
    max-width: 65ch;
    margin: 0 auto;
  }

  .archive-crumbs {
    font-size: 14px;
    color: var(--text-light);
    margin-bottom: 0.5rem;
  }

  .archive-crumbs a {
    color: var(--text-light);
    text-decoration: none;
  }

  .archive-crumbs a:hover {
    color: var(--accent);
  }

  .archive-count {
    color: var(--text-light);
    font-size: 14px;
    margin-top: 0.5rem;
  }

  .notes-stream {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .note-card {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 8px;
    padding: 1.1rem 1.35rem;
    overflow: hidden;
  }

  .note-card-header {
    margin-bottom: 0.5rem;
  }

  .note-card-header h2 {
    margin: 0 0 0.25rem;
    font-size: 1.25rem;
  }

  .note-card-header h2 a {
    color: var(--text);
    text-decoration: none;
  }

  .note-card-header h2 a:hover {
    color: var(--accent);
  }

  .note-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .note-card-content {
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .note-card-content > :first-child {
    margin-top: 0;
  }

  .note-card-content > :last-child {
    margin-bottom: 0;
  }

  .note-card-tags {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
    text-decoration: none;
    font-size: 13px;
  }

  .tag:hover {
    text-decoration: underline;
  }
</style>
