---
import { getCollection } from "astro:content";
import ConstellationIcon from "../components/ConstellationIcon.astro";
import KudosButton from "../components/KudosButton.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getArticleUrl } from "../lib/article-utils";
import { includeDraft } from "../lib/draft-utils";
import { createHomepagePreview } from "../lib/markdown-utils";
import { formatTitle } from "../lib/typography";

// Constellation lottie files — Vite resolves these to hashed URLs at build time.
// Only constellation files are imported; other/ files are not bundled unless used.
const constellationModules = import.meta.glob<string>(
  "../lottie/constellations/*.lottie",
  { query: "?url", import: "default", eager: true },
);

// name → URL map (e.g. "aquarius" → "/assets/aquarius.B9uJRUL3.lottie")
const constellationUrls: Record<string, string> = Object.fromEntries(
  Object.entries(constellationModules).map(([path, url]) => [
    path.split("/").pop()!.replace(".lottie", ""),
    url,
  ]),
);

function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) h = (h * 31 + s.charCodeAt(i)) | 0;
  return Math.abs(h);
}

const CONSTELLATION_NAMES = Object.keys(constellationUrls);

// Assign icons with no duplicates. Each article is processed in hash order
// so its slot is determined independently of display order — adding a new
// article only displaces others if it lands in an already-taken slot.
function assignIcons(
  ids: string[],
): Map<string, { url: string; slug: string }> {
  const result = new Map<string, { url: string; slug: string }>();
  const used = new Set<number>();
  for (const id of [...ids].sort((a, b) => hashStr(a) - hashStr(b))) {
    let idx = hashStr(id) % CONSTELLATION_NAMES.length;
    while (used.has(idx)) idx = (idx + 1) % CONSTELLATION_NAMES.length;
    used.add(idx);
    const slug = CONSTELLATION_NAMES[idx];
    result.set(id, { url: constellationUrls[slug], slug });
  }
  return result;
}

// Get recent articles (latest 5; drafts hidden unless SHOW_DRAFTS=1)
const articles = await getCollection("articles", ({ data }) =>
  includeDraft(data),
);

// Sort by date (newest first) and take first 5
const sortedArticles = articles
  .sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  )
  .slice(0, 5);

// Render articles with full markdown pipeline and h3 headings for homepage
const recentArticles = await Promise.all(
  sortedArticles.map(async (article) => {
    const { html, isTruncated } = await createHomepagePreview(article.body);

    return {
      ...article,
      transformedHtml: html,
      isTruncated,
      formattedTitle: await formatTitle(article.data.title),
    };
  }),
);

const iconAssignments = assignIcons(recentArticles.slice(1).map((a) => a.id));
---

<BaseLayout
  title="Tyler Butler — A Programmer's Home on the Web"
  description="Long-form articles, short notes, and project showcases from Tyler Butler — a programmer's own corner of the web. No algorithm, just posts."
>
  <div class="homepage-layout">
    <main class="main-content">
      {recentArticles.length > 0 && (
      <ul class="recent-articles">
        {recentArticles.map((article, index) => {
          const date = new Date(article.data.date);

          return (
            <>
              {index > 0 && (() => {
                const { url, slug } = iconAssignments.get(article.id)!;
                return (
                  <li class="article-divider" role="presentation" aria-hidden="true">
                    <ConstellationIcon src={url} slug={slug} size={64} />
                  </li>
                );
              })()}
            <li>
              <article class="article-preview">
                <h2>
                  <a href={getArticleUrl(article)}>
                    {article.formattedTitle}
                  </a>
                </h2>
                <div class="article-meta">
                  <time datetime={article.data.date.toISOString()}>
                    {date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </time>
                </div>
                <div class="article-content" set:html={article.transformedHtml}></div>
                <p class="preview-actions">
                  {article.isTruncated ? (
                    <a href={getArticleUrl(article)} class="read-more-link">Read More →</a>
                  ) : (
                    <a href={getArticleUrl(article)} class="read-more-link">Permalink →</a>
                  )}
                  <KudosButton path={getArticleUrl(article)} variant="preview" />
                </p>
              </article>
            </li>
            </>
          );
        })}
      </ul>
    )}

      <div class="stream-footer">
        <p class="stream-footer-more">
          <a href="/articles/">View All Articles →</a>
        </p>
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .homepage-layout {
    margin: 0;
  }

  .recent-articles {
    list-style: none;
    padding: 0;
    margin: 2em 0;
  }

  .article-preview {
    margin-bottom: 1.5em;
    padding-bottom: 1em;
  }

  .article-divider {
    display: flex;
    justify-content: center;
    margin: 1em 0 4em;
    list-style: none;
  }


  /* Size, face, and weight inherit from the global h2 ramp (typography.css) */
  .article-preview h2 {
    margin: 0 0 0.5em 0;
  }

  /* The primary CTA gets a resting link affordance: an accent underline that
     fades on hover while the color deepens — the site's link grammar, scaled
     optically for display size */
  .article-preview h2 a {
    color: var(--text);
    text-decoration: underline;
    text-decoration-color: var(--accent);
    text-decoration-thickness: 0.06em;
    text-underline-offset: 0.14em;
    transition:
      color 0.2s ease,
      text-decoration-color 0.3s ease;
  }

  .article-preview h2 a:hover {
    color: var(--accent);
    text-decoration-color: transparent;
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1em;
    margin-bottom: 0.5em;
  }

  .article-preview time {
    font-size: var(--font-size-meta);
    color: var(--text-light);
    text-transform: uppercase;
    letter-spacing: 1px;
    flex-shrink: 0;
  }

  /* Injected article HTML (set:html) is unscoped, so its typography comes
     from the global stylesheets — only the wrapper itself is styled here */
  .article-content {
    margin: 0.5em 0;
  }

  .preview-actions {
    margin: 1em 0 0 0;
    display: flex;
    align-items: center;
    gap: 0.75em;
  }

  /* Stream action chips share the kudos-button register: quiet italic serif
     on raised paper, filling with the accent on hover */
  .read-more-link {
    display: inline-block;
    background: var(--code-bg);
    border: 1px solid var(--text-light);
    padding: 4px 10px;
    font-size: var(--font-size-label);
    font-style: italic;
    color: var(--text);
    border-radius: var(--radius-md);
    text-decoration: none;
  }

  .read-more-link:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--light-bg);
  }

  .preview-actions :global(.tinylytics_kudos) {
    font-size: var(--font-size-label);
    padding: 2px 8px;
  }

  /* Touch: grow the adjacent action chips to comfortable thumb targets
     (≥40px hit height) and widen the gap between them */
  @media (pointer: coarse) {
    .preview-actions {
      gap: 1.25em;
    }

    .read-more-link {
      padding: 12px 16px;
    }

    .preview-actions :global(.tinylytics_kudos) {
      padding: 10px 14px;
    }
  }

  /* End-of-stream: the archive is the way onward; the subscribe pitch
     lives in the site footer (the back cover) just below */
  .stream-footer {
    margin: 3em 0 1em;
    text-align: center;
  }

  .stream-footer-more {
    margin: 0;
  }
</style>
