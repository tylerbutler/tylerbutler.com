---
interface Props {
  path: string;
  variant?: "article" | "preview";
}

const { path, variant = "article" } = Astro.props;
const wrapperClass = variant === "article" ? "article-kudos" : "preview-kudos";
const labelClass =
  variant === "article" ? "article-kudos-label" : "preview-kudos-label";
---

{
  variant === "article" ? (
    <div class={wrapperClass}>
      <span class={labelClass}>I like this</span>
      <button
        class="tinylytics_kudos"
        data-path={path}
        type="button"
        aria-label="I like this"
      />
      <span class="kudos-suffix" hidden>
        — and so do <span class="kudos-count" /> others
      </span>
    </div>
  ) : (
    <span class={wrapperClass}>
      <span class={labelClass}>I like this</span>
      <button
        class="tinylytics_kudos"
        data-path={path}
        type="button"
        aria-label="I like this"
      />
      <span class="kudos-suffix" hidden>
        — and so do <span class="kudos-count" /> others
      </span>
    </span>
  )
}

<script>
  // Tinylytics is configured with ?kudos=custom, so the script injects
  // only the count into the button. We move it to the sibling suffix
  // span when it clears the threshold; the rocket emoji is a CSS
  // ::before pseudo-element and is unaffected by clearing the button.
  const KUDOS_THRESHOLD = 10;

  function updateKudos(btn: HTMLElement) {
    const text = btn.textContent?.trim() ?? "";
    const parent = btn.parentElement;
    const suffix = parent?.querySelector<HTMLElement>(".kudos-suffix") ?? null;
    const countEl = parent?.querySelector<HTMLElement>(".kudos-count") ?? null;
    if (text === "") {
      if (suffix) suffix.hidden = true;
      return;
    }
    const count = Number.parseInt(text, 10);
    if (!Number.isFinite(count)) return;
    btn.textContent = "";
    if (count > KUDOS_THRESHOLD && suffix && countEl) {
      countEl.textContent = String(count);
      suffix.hidden = false;
    } else if (suffix) {
      suffix.hidden = true;
    }
  }

  for (const btn of document.querySelectorAll<HTMLElement>(
    ".tinylytics_kudos",
  )) {
    updateKudos(btn);
    const observer = new MutationObserver(() => updateKudos(btn));
    observer.observe(btn, {
      childList: true,
      characterData: true,
      subtree: true,
    });
  }
</script>
