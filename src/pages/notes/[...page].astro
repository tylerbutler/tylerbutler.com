---
import { type CollectionEntry, getCollection, render } from "astro:content";
import type { GetStaticPaths } from "astro";
import NoteDate from "../../components/NoteDate.astro";
import NotePermalink from "../../components/NotePermalink.astro";
import NoteSourceIcon from "../../components/NoteSourceIcon.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { includeDraft } from "../../lib/draft-utils";
import { getNoteUrl } from "../../lib/note-utils";
import "../../lib/styles/page-nav.css";

const MS_PER_YEAR = 365.25 * 24 * 60 * 60 * 1000;

export const getStaticPaths = (async ({ paginate }) => {
  const notes = await getCollection("notes", ({ data }) => includeDraft(data));
  const sorted = notes.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
  );
  return paginate(sorted, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props as {
  page: {
    data: CollectionEntry<"notes">[];
    url: { prev?: string; next?: string; current: string };
    currentPage: number;
    lastPage: number;
    total: number;
  };
};

const renderedNotes = await Promise.all(
  page.data.map(async (note) => {
    const { Content } = await render(note);
    return { note, Content };
  }),
);

const pageTitle =
  page.currentPage > 1
    ? `Notes - Page ${page.currentPage} - Tyler Butler`
    : "Notes - Tyler Butler";
---

<BaseLayout
  title={pageTitle}
  description="Short-form notes by Tyler Butler."
>
  <section class="notes-page h-feed">
    <h1>Notes</h1>
    {page.lastPage > 1 && (
      <p class="page-indicator">
        Page {page.currentPage} of {page.lastPage}
      </p>
    )}

    {renderedNotes.length === 0 && (
      <p class="empty-state">No notes published yet.</p>
    )}

    <div class="notes-stream">
      {renderedNotes.map(({ note, Content }, i) => {
        const url = getNoteUrl(note);
        const older = renderedNotes[i + 1];
        const gap = older
          ? Math.round(
              (note.data.date.getTime() - older.note.data.date.getTime()) /
                MS_PER_YEAR,
            )
          : 0;
        const showGap = gap >= 2;

        return (
          <Fragment>
            <article class="note-card h-entry">
              <header class="note-card-header">
                {note.data.title && (
                  <h3 class="p-name">
                    <a href={url} class="u-url">{note.data.title}</a>
                  </h3>
                )}
                <span class="note-meta">
                  <NoteSourceIcon source={note.data.source} />
                  <NoteDate note={note} className="note-permalink" />
                  <NotePermalink note={note} />
                </span>
              </header>

              <div class="note-card-content e-content">
                <Content />
              </div>

              {note.data.tags && note.data.tags.length > 0 && (
                <div class="note-card-tags">
                  {note.data.tags.map((tag) => (
                    <a href={`/tags/${tag}/`} class="tag p-category">#{tag}</a>
                  ))}
                </div>
              )}
            </article>

            {showGap && (
              <div class="note-gap" role="separator">
                <span>{gap} years of silent reflection</span>
              </div>
            )}
          </Fragment>
        );
      })}
    </div>

    {page.lastPage > 1 && (
      <nav class="article-nav">
        {page.url.prev && (
          <a href={page.url.prev} class="nav-link">
            <span class="nav-arrow">←</span>
            <span class="nav-text">Newer notes</span>
          </a>
        )}
        {page.url.next && (
          <a href={page.url.next} class="nav-link nav-link-next">
            <span class="nav-text">Older notes</span>
            <span class="nav-arrow">→</span>
          </a>
        )}
      </nav>
    )}
  </section>
</BaseLayout>

<style>
  .notes-page {
    max-width: 65ch;
    margin: 0 auto;
  }

  .page-indicator {
    color: var(--text-light);
    font-size: 13px;
    margin: 0.25rem 0 1.5rem;
  }

  .notes-stream {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .note-card {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 8px;
    padding: 1.1rem 1.35rem;
    overflow: hidden;
  }

  .note-card-header {
    margin-bottom: 0.5rem;
  }

  .note-card-header h3 {
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
  }

  .note-card-header h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .note-card-header h3 a:hover {
    color: var(--accent);
  }

  .note-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .note-permalink {
    color: var(--text-light);
    text-decoration: none;
    font-size: 13px;
    font-variant-numeric: tabular-nums;
  }

  .note-permalink:hover {
    color: var(--accent);
  }

  .note-card-content {
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .note-card-content > :first-child {
    margin-top: 0;
  }

  .note-card-content > :last-child {
    margin-bottom: 0;
  }

  .note-card-tags {
    margin-top: 0.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    color: var(--accent);
    text-decoration: none;
    font-size: 13px;
  }

  .tag:hover {
    text-decoration: underline;
  }

  .note-gap {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: var(--text-light);
    font-style: italic;
    font-size: 13px;
    text-align: center;
    margin: 2rem 0 1rem;
  }

  .note-gap::before,
  .note-gap::after {
    content: "";
    flex: 1;
    border-top: 1px solid var(--code-border);
  }

  .empty-state {
    color: var(--text-light);
    font-style: italic;
  }
</style>
